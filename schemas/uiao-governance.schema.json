{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uiao.example.org/schemas/uiao-governance.schema.json",
  "title": "UIAO Governance Metadata Schema",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/document"
    },
    {
      "$ref": "#/$defs/adr"
    }
  ],
  "$defs": {
    "uiaoBase": {
      "type": "object",
      "required": [
        "id",
        "status",
        "owner",
        "tags",
        "created",
        "lastUpdated",
        "commit"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^UIAO_[A-Z_]+_[0-9]{2,}$"
        },
        "status": {
          "type": "string",
          "enum": [
            "Current",
            "Draft",
            "Needs Replacing",
            "Needs Creating",
            "Deprecated"
          ]
        },
        "owner": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "created": {
          "type": "string",
          "format": "date"
        },
        "lastUpdated": {
          "type": "string",
          "format": "date"
        },
        "commit": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "document": {
      "title": "UIAO Document (non-ADR)",
      "type": "object",
      "required": [
        "title",
        "uiao",
        "summary"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "uiao": {
          "$ref": "#/$defs/uiaoBase"
        },
        "summary": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "fabric": {
          "type": "string",
          "enum": [
            "identity",
            "drift",
            "evidence",
            "adapter",
            "governance",
            "meta",
            "architecture",
            "operations",
            "compliance"
          ]
        }
      },
      "additionalProperties": true
    },
    "adr": {
      "title": "UIAO Architecture Decision Record",
      "type": "object",
      "required": [
        "title",
        "id",
        "status",
        "date",
        "deciders",
        "tags",
        "affects",
        "uiao",
        "summary"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "id": {
          "type": "string",
          "pattern": "^ADR-[0-9]{3,}$"
        },
        "status": {
          "type": "string",
          "enum": [
            "Proposed",
            "Accepted",
            "Superseded",
            "Deprecated",
            "Replaced"
          ]
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "deciders": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "consulted": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "affects": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^UIAO_[A-Z_]+_[0-9]{2,}$"
          },
          "minItems": 1
        },
        "supersedes": {
          "type": "string",
          "pattern": "^ADR-[0-9]{3,}$"
        },
        "supersededBy": {
          "type": "string",
          "pattern": "^ADR-[0-9]{3,}$"
        },
        "uiao": {
          "$ref": "#/$defs/uiaoBase"
        },
        "summary": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "fabric": {
          "type": "string",
          "enum": [
            "identity",
            "drift",
            "evidence",
            "adapter",
            "governance",
            "meta",
            "architecture",
            "operations",
            "compliance"
          ]
        }
      },
      "additionalProperties": true
    }
  }
}
