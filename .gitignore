# ============================================
# UIAO Canonical .gitignore
# Prevents drift, export contamination, and noise
# ============================================

# --- Generated Documents (never commit) ---
# Note: data/docx-reference.docx and data/pptx-reference.pptx are
# style reference files, not generated output. They MUST be tracked.
*.pdf
*.html
*.csv

# Ignore generated DOCX/PPTX in _site and exports, but not data/
_site/**/*.docx
_site/**/*.pptx
exports/**/*.docx
exports/**/*.pptx

# --- Quarto Outputs ---
/_site/
site/
/docs/*.html
# Note: *.qmd files are Quarto source files and MUST be tracked.
# They were renamed from .md as part of the Quarto pipeline migration.

# --- Export Directories ---
exports/
exports/**

# --- Rendered Diagrams ---
*.png.rendered
*.svg.rendered

# --- Temporary / Local Files ---
~$*
*.tmp
*.bak
*.swp
.DS_Store
Thumbs.db

# --- Python / Build Artifacts ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# --- Node / JS (if ever used) ---
node_modules/

# --- VSCode / IDE ---
.vscode/
.idea/

# --- Logs ---
*.log

# --- mkdocs backups (created by Initialize-UIAOCanonStructure.ps1) ---
mkdocs.yml.backup-*

# --- Root-level stray files (tree dumps, scratch files) ---
DocTree.txt
uiao-docs_DirTree.txt
uiao-docs_tree.txt
uiao-docs-tree.txt
uaio-docs_docx.txt
1

# --- Root-level scripts (should live in scripts/) ---
/Initialize-UIAOCanonStructure.ps1

# --- Root-level SUMMARY.md is intentional, but root-level .docx/.xlsx are not ---
/*.docx
/*.xlsx

# --- Binary reference files in docs/governance (local working docs, not canon) ---
docs/governance/*.docx
docs/governance/*.png

# --- References folder (local working docs, not canon) ---
references/
references/**

/.quarto/
**/*.quarto_ipynb

# Ignore Claude artifacts
.claude/

.claude/
